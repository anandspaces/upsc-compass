# =============================================================================
# UPSC Compass Auth API — environment variables
# Copy to .env and fill in values. Bun loads .env automatically.
# =============================================================================

# --- Server ------------------------------------------------------------------
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed CORS origins. Use "*" only for local dev.
CORS_ORIGINS=*

# --- Database (PostgreSQL) ---------------------------------------------------
# Primary database connection string used by the app and migrations.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/upsccompass_db

# Separate connection string used by the e2e test suite. Should point at a
# dedicated database — its tables are dropped/recreated on each test run.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/upsccompass_test

# --- JWT ---------------------------------------------------------------------
# Use a long random string (>= 32 chars). Generate with: openssl rand -hex 64
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_ISSUER=upsccompass

# --- OTP ---------------------------------------------------------------------
# Server-side secret used to HMAC OTP codes before storing them.
OTP_SECRET=replace-me-with-another-long-random-string
OTP_EXPIRY_MINUTES=10
OTP_MAX_VERIFY_ATTEMPTS=3
OTP_RESEND_WINDOW_MINUTES=10
OTP_RESEND_MAX_PER_WINDOW=3

# --- Password hashing --------------------------------------------------------
# bcrypt cost factor. Spec mandates >= 12. Use 4 only for tests/local dev.
BCRYPT_COST=12

# --- Email delivery ----------------------------------------------------------
# Provider: "console" (dev — logs OTP to stdout) or "smtp" (real email via nodemailer)
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@dextora.app
EMAIL_FROM_NAME=Dextora UPSC Compass

# Required when EMAIL_PROVIDER=smtp.
# Gmail setup:
#   1. Enable 2-Step Verification on the sending Google account.
#   2. Create a 16-character App Password at https://myaccount.google.com/apppasswords
#      (select "Mail" + "Other") and paste it as SMTP_PASSWORD below — no spaces.
#   3. Use the Gmail address as SMTP_USER and (typically) as EMAIL_FROM.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
